export function processRoadBetSelections(roadBetSelections: Record<string, Record<string, Record<string, string | number>>>, nextBetId: string, lotteryId: any, multiplier: number): Array<Record<string, any>> {
  const results: Array<Record<string, any>> = [];
  const groupType: any = {
