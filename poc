 */
export function actualProfitBet(
  gameId: number, 
  userPrize: any, 
  totalBetsAmt: number,
  multiplier: number,
  selections: any
): number {

  if (gameId === 99) {
    // Multiple selection game
    return fixArithmetic(
      (userPrize * filterSelections(selections).length) - totalBetsAmt
    );

  } else {
    // Non-multiple selection game
    return fixArithmetic(
      (multiplier * (isNaN(userPrize) ? Math.max(...userPrize.split("~")) : userPrize)) - 
      totalBetsAmt
    );
  }
}
