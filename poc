  return joinedArr.join(', ');
}


/**
 * Analyzes the left and right pairs of draw numbers and provides analysis results.
 *
 * @param {number[]} drawNumbers - draw numbers.
 * @returns {string[]} Analysis results, including which is greater (village or idle) and pair checks.
 */
export function calculateBaccaratResult(drawNumbers: number[]): string[] {
  const [leftPair, rightPair] = splitIntoPairs(drawNumbers);
  let left = sumPair(leftPair);
  let right = sumPair(rightPair);

  return [
    checkWhichIsGreater(padNumberWithZeros(left), padNumberWithZeros(right)),
    ...checkIdlePairOrZhuang(leftPair, rightPair),
  ];
}

/**
 * Sums the elements in an array.
 *
 * @param {number[]} pair - The array of numbers to be summed.
 * @returns {number} The sum of the numbers in the array.
 */
export function sumPair(pair: number[]): number {
  return pair?.reduce((a, b) => a + b, 0);
}

/**
 * Pads a number with leading zeros if it is less than 10.
 *
 * @param {number} num - The number to be padded.
 * @returns {string} The padded number as a string.
 */
export function padNumberWithZeros(num: number): string {
  return num < 10 ? num?.toString().padStart(2, "0") : num?.toString();
}

/**
 * Compares the units place of two numbers and returns the comparison result.
 *
 * @param {string} village - The village number.
 * @param {string} idle - The idle number.
 * @returns {string} The comparison result: "village", "idle", or "and".
 */
export function checkWhichIsGreater(village: string, idle: string): string {
  let _village = village?.[1];
  let _idle = idle?.[1];

  if (_village > _idle) return "Banker Lose";
  if (_village < _idle) return "Player Lose";
  return "Draw";
}

/**
 * Checks for a Zhuang pair and/or an Idle pair and returns the results.
 *
 * @param {number[]} arr - The array representing one pair of draw numbers.
 * @param {number[]} values - The array representing another pair of draw numbers.
 * @returns {string[]} An array of results, including "Zhuang" and/or "Idle pair".
 */
export function checkIdlePairOrZhuang(arr: number[], values: number[]): string[] {
  let final: string[] = [];

  if (arr?.[0] === arr?.[1]) {
    final.push("Banker Pair");
  }

  if (values?.[0] === values?.[1]) {
    final.push("Player Pair");
  }

  return final;
}

