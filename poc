    for (const element of game_type) {
      combineGameTypeAndUserSelection.push(data[game_name][element]);
      // console.log(game_type[j])
    }
  }

  const basket = combineGameTypeAndUserSelection.map((item) =>
    Object.entries(item).flatMap(([key, values]) => [[key, values]])
  );

  // spreaking basket items into one array
  const resultFlat = basket.flat();

  //filtering all arrays from the basket
  const filteredArrayResult = resultFlat.filter((item) => Array.isArray(item[1]));

  //filtering all objects from the basket
  const filteredAObjectResult = resultFlat.filter(
    (item) => !Array.isArray(item[1])
  );

  // converting all objects to array
  const flatFilteredObjectResult = filteredAObjectResult.map((arr: any) =>
    Object.entries(arr[1]).map(([key, value]) => [arr[0], [Number(key), value]])
  );

  const finalFlatArrayMap = filteredArrayResult.map((arr) => arr.flat());
  const finalFlatObjectMap = flatFilteredObjectResult
    .flat()
    .map((arr) => arr.flat());

  const combineArrays = [finalFlatArrayMap, finalFlatObjectMap].flat();

  const finalDataToBeSent = combineArrays.map(([gameName, userSelections, amount]) => ({
    betId: "5654546",
    game_id: 3,
    game_name: gameName,
    amount,
    userSelections,
    allSelections: userSelections,
  }));

  return finalDataToBeSent
}






