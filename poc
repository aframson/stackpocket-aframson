/**
 * Sorts an array of numbers in ascending or descending order.
 * @param drawNumbers - The array of numbers to be sorted.
 * @param order - The sorting order, "asc" for ascending (default) or "desc" for descending.
 * @returns A new array containing the sorted numbers.
 */
function sortNumbersInArray(drawNumbers: number[], order: "asc" | "desc" = "asc"): number[] {
  if (order === "desc") {
    return drawNumbers.sort((a, b) => b - a);
  } else {
    return drawNumbers.sort((a, b) => a - b);
  }
}

/**
 * Checks if the given array of numbers forms a streak.
 * @param array - The array of numbers to check for a streak.
 * @returns True if the array forms a streak, otherwise false.
 */
// function isStreak(array: number[]): boolean {
//   let streak = array.every((_, i, arr) => {
//     if (i === arr.length - 1) return true;
//     return arr[i] + 1 === arr[i + 1] || arr[i] + 9 === arr[arr.length - 1];
//   });
//   return streak;
// }
function isStreak(drawNumber: number[], streakLength: number): boolean {
  const sortedDrawNumbers = [...drawNumber].sort((a, b) => a - b);

  for (let i = 0; i < sortedDrawNumbers.length; i++) {
    let count = 1;
    let currentIndex = i;

    for (let j = 0; j < streakLength - 1; j++) {
      const nextIndex = (currentIndex + 1) % sortedDrawNumbers.length;

      if (sortedDrawNumbers[nextIndex] === sortedDrawNumbers[currentIndex] + 1 ||
        (sortedDrawNumbers[nextIndex] === 0 && sortedDrawNumbers[currentIndex] === 9)) {
        count++;
        currentIndex = nextIndex;
      } else {
        break;
      }
    }

    if (count === streakLength) {
      return true;
    }
  }

  return false;
}


/**
 * Checks if the given array of numbers forms a half-streak.
 * @param array - The array of numbers to check for a half-streak.
 * @returns True if the array forms a half-streak, otherwise false.
 */
function isHalfStreak(array: number[]): any {
  let streak = sortNumbersInArray(array).some((_, i, arr) => {
    return arr[i] + 1 === arr[i + 1] || arr[i] + 9 === arr[arr.length - 1];
  });
  return streak;
}

