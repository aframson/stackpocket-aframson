/**
 * Process the bet information.
 * @param main_name - The main name object containing the bet information.
 * @returns An array of processed results.
 */
export function processBetInfo(main_name: Record<string, any>, drawData: { nextBetId: any; }, lottery_id: any, multiplier: number): Array<Record<string, any>> {
  let results: Array<Record<string, any>> = [];

  for (let game_label in main_name) {
    let g_name = main_name[game_label];

    for (let position in g_name) {
      let selection = g_name[position];

      for (let sel in selection) {
        let result: Record<string, any> = {};

        if (Array.isArray(selection[sel])) {
          let f = {
            /**
             * Object representing all selections.
             * @property position - The position.
             * @property selection - The selection.
             * @property label_id - The label ID.
             */
            allSelections: { position: position, selection: selection[sel][0], label_id: selection[sel][2] },
            betId: drawData.nextBetId,
            bet_date: getDate("" + new Date()),
            bet_time: getTimeTwo(new Date()),
            gameId: selection[sel][3],//fetch from api
            game_label: game_label,
            lottery_id: lottery_id,
            multiplier: multiplier,
            totalBetAmt: Number(selection[sel][1]),
            totalBets: 1,
            uid: results.length + 1,
            unitStaked: 1,
            userSelections: `${sel} ${position} ${selection[sel][0]}`
          };
          result = { ...result, ...f };
        }

        if (!Array.isArray(selection[sel])) {
          for (let key in selection[sel]) {
            let f = {
              /**
               * Object representing all selections.
               * @property position - The position.
               * @property selection - The selection.
               * @property label_id - The label ID.
               */
              allSelections: { position: position, selection: key, label_id: Object.keys(Object.values(selection[sel][key])[0] as any)[0] },
              betId: drawData.nextBetId,
              bet_date: getDate("" + new Date()),
              bet_time: getTimeTwo(new Date()),
              gameId: Object.values(Object.values(selection[sel][key])[0] as any)[0],//fetch from api
              game_label: game_label,
              lottery_id: 1,
              multiplier: multiplier,
              totalBetAmt: +Object.keys(selection[sel][key])[0],
              totalBets: 1,
              uid: results.length + 1,
              unitStaked: 1,
              userSelections: `${sel} ${position} ${key}`
            };
            result = { ...result, ...f };
            results.push(result); // Move the push inside the loop
          }
        } else {
          results.push(result); // Move the push inside the loop
        }
      }
    }
  }

  return results;
}


