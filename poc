export function TwoSidesBetNow(data: any) {
  let gameNames: any[] = [];
  const combineGameNamesAndType = [];
  let combineGameTypeAndUserSelection = [];

  Object.keys(data).forEach((item: any) => {
    gameNames.push(item);
  });

  for (const element of gameNames) {
    let game_name = element;
    let game_type = Object.keys(data[element]);
    combineGameNamesAndType.push([game_name, game_type]);
  }
  // console.log(combineGameNamesAndType);
  for (const element of combineGameNamesAndType) {
    let game_name = element[0];
