export const handleChange = (
  e: ChangeEvent<HTMLInputElement>,
  bet_items: any,
  bet_title: string,
  game_name: string,
  action_type: string,
  two_sides_dispatch: any,
  setInputValues: any,
): void => {
  const { value } = e.target as HTMLInputElement;

  // Remove non-digit characters from the value
  let parsedValue = value.replace(/\D+/g, "");

  // Check if the parsed value is empty
  if (isEmpty(parsedValue)) {
    parsedValue = "";
  }

  // Check if the parsed value is a valid number
  const isValidNumber = !isNaN(+parsedValue);

  // Limit the value to be less than or equal to 99999
  const limitedValue = +parsedValue > 99999 ? 99999 : parsedValue;

  console.log("==========================>isValidNumber", `${isNaN(bet_items?.label) ? bet_items?.label : `_${bet_items?.label}`}`);
  console.log("==========================>isValidNumber", `${isNaN(bet_items?.label) ? bet_items?.label : `_${bet_items?.label}`}-${removeWhiteSpaces(bet_items?.key)
    }${bet_title}`);
  setInputValues((prevValues: any) => ({
    ...prevValues,
    [`${isNaN(bet_items?.label) ? removeWhiteSpaces(bet_items?.label) : `_${removeWhiteSpaces(bet_items?.label)}`}-${removeWhiteSpaces(bet_items?.key)
      }${bet_title}`]: limitedValue,
  }));
  // rowId: item.key,
  // userSelection: item.label,
  // position: name,
  // game_name: name,
  // amount: amt,
  // label_id: item.labelid
  two_sides_dispatch({
    type: action_type,
    payload: {
      rowId: bet_items?.key,
      userSelection: bet_items?.label,
      position: bet_title,
      game_name: game_name,
      amount: isValidNumber ? limitedValue : 99999,
      label_id: "" + bet_items.labelid,
      game_id: "" + bet_items.gameid
    },
  });

};

export function deepCopy(obj: any) {
  if (obj === null || typeof obj !== 'object') {
    return obj;
  }

  const copy: any = Array.isArray(obj) ? [] : {};

  for (const key in obj) {
    if (obj.hasOwnProperty(key)) {
      copy[key] = deepCopy(obj[key]);
    }
  }

  return copy;
}

