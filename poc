 *
 * @param {number[]} drawNumber - The array of draw numbers.
 * @returns {number[][]} An array containing two pairs of draw numbers.
 */
export function splitIntoPairs(drawNumber: number[]): number[][] {
  let first = drawNumber?.slice(0, 2);
  let second = drawNumber?.slice(3);

  return [first, second];
}


